<interface>
	<template class="ZapZapItem">
		<property name="layout-manager">
			<object class="GtkBinLayout"/>
		</property>
		<property name="overflow">hidden</property>
		<binding name="playing">
			<lookup name="playing" type="Zap">
				<lookup name="zap">ZapZapItem</lookup>
			</lookup>
		</binding>
		<child>
			<object class="ZapProgressBar">
				<binding name="progress">
					<lookup name="progress" type="Zap">
						<lookup name="zap">ZapZapItem</lookup>
					</lookup>
				</binding>
			</object>
		</child>
		<child>
			<object class="GtkBox">
				<child>
					<object class="GtkRevealer" id="stopButtonRevealer">
						<signal name="notify::child-revealed" handler="onStopButtonRevealChanged"/>
						<property name="transition-type">slide-left</property>
						<binding name="reveal-child">
							<lookup name="playing" type="Zap">
								<lookup name="zap">ZapZapItem</lookup>
							</lookup>
						</binding>
						<property name="child">
							<object class="GtkBox">
								<property name="orientation">vertical</property>
								<child>
									<object class="GtkButton" id="stopButton">
										<signal name="clicked" handler="onStopButtonClicked"/>
										<property name="tooltip-text" translatable="yes">Stop</property>
										<property name="icon-name">fr.romainvigier.zap-stop-symbolic</property>
										<style>
											<class name="stop"/>
										</style>
									</object>
								</child>
								<child>
									<object class="GtkButton" id="fadeOutButton">
										<signal name="clicked" handler="onFadeOutButtonClicked"/>
										<property name="tooltip-text" translatable="yes">Fade out</property>
										<property name="icon-name">fr.romainvigier.zap-fadeout-symbolic</property>
										<style>
											<class name="fadeout"/>
										</style>
									</object>
								</child>
							</object>
						</property>
					</object>
				</child>
				<child>
					<object class="GtkButton" id="playButton">
						<signal name="clicked" handler="onPlayButtonClicked"/>
						<property name="tooltip-text" translatable="yes">Play</property>
						<property name="hexpand">true</property>
						<property name="child">
							<object class="GtkBox">
								<property name="spacing">12</property>
								<child>
									<object class="GtkImage" id="playImage">
										<binding name="icon-name">
											<closure type="gchararray" function="getPlayPauseIcon">
												<lookup name="playing" type="Zap">
													<lookup name="zap">ZapZapItem</lookup>
												</lookup>
												<lookup name="paused" type="Zap">
													<lookup name="zap">ZapZapItem</lookup>
												</lookup>
											</closure>
										</binding>
									</object>
								</child>
								<child>
									<object class="GtkLabel" id="nameInscription">
										<binding name="label">
											<lookup name="name" type="Zap">
												<lookup name="zap">ZapZapItem</lookup>
											</lookup>
										</binding>
										<property name="ellipsize">end</property>
										<property name="hexpand">true</property>
										<property name="xalign">0</property>
									</object>
								</child>
								<child>
									<object class="GtkLabel" id="hotkeyLabel">
										<property name="valign">center</property>
										<binding name="label">
											<lookup name="hotkey" type="Zap">
												<lookup name="zap">ZapZapItem</lookup>
											</lookup>
										</binding>
										<binding name="visible">
											<closure type="gboolean" function="isHotkeyNotEmpty">
												<lookup name="hotkey" type="Zap">
													<lookup name="zap">ZapZapItem</lookup>
												</lookup>
											</closure>
										</binding>
										<style>
											<class name="dim-label"/>
											<class name="caption"/>
											<class name="hotkey"/>
										</style>
									</object>
								</child>
							</object>
						</property>
						<accessibility>
							<relation name="labelled-by">nameInscription</relation>
						</accessibility>
						<style>
							<class name="play"/>
						</style>
					</object>
				</child>
				<child>
					<object class="GtkBox">
						<property name="orientation">vertical</property>
						<child>
							<object class="GtkToggleButton">
								<signal name="toggled" handler="onLoopButtonToggled"/>
								<property name="tooltip-text" translatable="yes">Loop</property>
								<property name="icon-name">fr.romainvigier.zap-repeat-symbolic</property>
								<binding name="active">
									<lookup name="loop" type="Zap">
										<lookup name="zap">ZapZapItem</lookup>
									</lookup>
								</binding>
								<style>
									<class name="loop"/>
								</style>
							</object>
						</child>
						<child>
							<object class="GtkMenuButton">
								<property name="tooltip-text" translatable="yes">Edit</property>
								<property name="icon-name">fr.romainvigier.zap-edit-symbolic</property>
								<property name="popover">
									<object class="ZapEditZapPopover">
										<property name="zap" bind-source="ZapZapItem" bind-property="zap" bind-flags="sync-create"/>
									</object>
								</property>
								<style>
									<class name="edit"/>
								</style>
							</object>
						</child>
					</object>
				</child>
			</object>
		</child>
		<child>
			<object class="GtkDragSource">
				<signal name="prepare" handler="onDragPrepare"/>
				<property name="actions">move</property>
			</object>
		</child>
		<child>
			<object class="GtkDropTarget">
				<signal name="notify::value" handler="onDropValueChanged"/>
				<signal name="drop" handler="onDrop"/>
				<property name="actions">move</property>
				<property name="formats">Zap</property>
				<property name="preload">true</property>
			</object>
		</child>
	</template>
</interface>
